{
  "name": "@eventora/email-builder",
  "version": "0.1.0",
  "description": "Framework-agnostic drag-and-drop email builder for React. Themable, localizable, exports email-safe HTML.",
  "type": "module",
  "license": "MIT",
  "author": "Eventora",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eventora/email-builder.git"
  },
  "homepage": "https://github.com/eventora/email-builder#readme",
  "bugs": {
    "url": "https://github.com/eventora/email-builder/issues"
  },
  "keywords": [
    "email",
    "email-builder",
    "email-editor",
    "drag-and-drop",
    "react",
    "email-template",
    "wysiwyg",
    "mjml-alternative"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:js && npm run build:css",
    "build:js": "tsup",
    "build:css": "postcss src/styles.css -o dist/styles.css --no-map",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@dnd-kit/core": ">=6.0.0",
    "@monaco-editor/react": ">=4.0.0",
    "clsx": ">=2.0.0",
    "lucide-react": ">=0.300.0",
    "nanoid": ">=4.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "tailwind-merge": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "@monaco-editor/react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@monaco-editor/react": "^4.7.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.23",
    "clsx": "^2.1.1",
    "lucide-react": "^0.462.0",
    "nanoid": "^5.1.7",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "postcss-prefix-selector": "^1.16.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "tsup": "^8.5.0",
    "typescript": "~5.9.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
